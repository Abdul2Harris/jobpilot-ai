#!/bin/sh

REPO_ROOT=$(pwd)

echo "Running type checks before commit..."

cd "$REPO_ROOT/frontend" && npx tsc --noEmit
FRONTEND_EXIT=$?

cd "$REPO_ROOT/backend" && npx tsc --noEmit
BACKEND_EXIT=$?

if [ $FRONTEND_EXIT -ne 0 ] || [ $BACKEND_EXIT -ne 0 ]; then
  echo ""
  echo "TypeScript errors found. Fix them before committing."
  exit 1
fi

echo "Type checks passed."
echo "Running ESLint on staged frontend files..."

cd "$REPO_ROOT/frontend" && npx lint-staged
LINT_EXIT=$?

if [ $LINT_EXIT -ne 0 ]; then
  echo ""
  echo "ESLint errors found. Fix them before committing."
  exit 1
fi

echo "All checks passed."
