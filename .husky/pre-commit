#!/usr/bin/env sh

REPO_ROOT=$(git rev-parse --show-toplevel)

echo "Running pre-commit checks..."

# Type check frontend
cd "$REPO_ROOT/frontend" && npm run typecheck ||
(
  echo "TypeScript check failed on frontend.
        Fix the type errors above and try committing again."
  false
)

# Type check backend
cd "$REPO_ROOT/backend" && npx tsc --noEmit ||
(
  echo "TypeScript check failed on backend.
        Fix the type errors above and try committing again."
  false
)

# Lint frontend
cd "$REPO_ROOT/frontend" && npm run lint ||
(
  echo "ESLint check failed.
        Fix the lint errors above and try committing again."
  false
)

# Build frontend (catches errors that tsc/eslint miss)
echo "Building frontend to catch any build errors..."
cd "$REPO_ROOT/frontend" && npm run build ||
(
  echo "Next.js build failed.
        Fix the build errors above and try committing again."
  false
)

echo "All checks passed. Committing now."
